# ═══════════════════════════════════════════════════════════════════════════
#  HuggingHermes — Environment Configuration
#  Deploy Hermes Agent on HuggingFace Spaces
# ═══════════════════════════════════════════════════════════════════════════
#
#  Usage:
#    Local Docker  →  cp .env.example .env  →  fill in values  →  docker run --env-file .env
#    HF Spaces     →  Set each variable as a "Repository Secret" in Space Settings
#
# ═══════════════════════════════════════════════════════════════════════════


# ─── DATA PERSISTENCE ────────────────────────────────────────────────────
#
# HuggingHermes auto-syncs /opt/data to a private HF Dataset repo,
# so your conversations, skills, memories, and config survive restarts.
#
# HuggingFace Access Token with WRITE permission.
# Create one at: https://huggingface.co/settings/tokens
#
# [REQUIRED]
#
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Target Dataset repository for data backup.
# Format: your-username/repo-name
#
# [OPTIONAL] Auto-derived from SPACE_ID if not set
#
# HERMES_DATASET_REPO=your-username/HuggingHermes-data

# Whether to auto-create the Dataset repo if it doesn't exist.
#
# [OPTIONAL]  Default: true
#
AUTO_CREATE_DATASET=true

# How often (in seconds) to back up data to the Dataset repo.
#
# [OPTIONAL]  Default: 60
#
# SYNC_INTERVAL=60


# ─── LLM PROVIDERS ────────────────────────────────────────────────────────
#
# Hermes Agent supports multiple providers: Nous Portal, OpenRouter,
# OpenAI, Anthropic, and custom endpoints.
#
# [RECOMMENDED] At least one of the following
#
# OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NOUS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ─── MESSAGING PLATFORMS ─────────────────────────────────────────────────
#
# Hermes supports Telegram, Discord, Slack, WhatsApp, Signal, and more.
# Configure via environment variables or config.yaml.
#
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# DISCORD_BOT_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ─── PERFORMANCE ──────────────────────────────────────────────────────────
#
# [OPTIONAL]  Default: UTC
#
# TZ=Asia/Shanghai


# ─── HERMES AGENT CONFIG ─────────────────────────────────────────────────
#
# Agent name displayed in messaging platforms
#
# AGENT_NAME=HuggingHermes
#
# Web dashboard port (internal — mapped to 7860 for HF Spaces)
#
# HERMES_WEB_PORT=7860
